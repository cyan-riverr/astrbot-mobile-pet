<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="1dp" android:top="2dp" android:right="1dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#286493C7" />
        </shape>
    </item>
    <item android:left="2dp" android:top="1dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:angle="135"
                android:startColor="#7CC4F5"
                android:centerColor="#5BADE8"
                android:endColor="#6DB9EF"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#78FFFFFF" />
        </shape>
    </item>
    <item android:left="10dp" android:top="5dp" android:right="10dp" android:bottom="25dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="270"
                android:startColor="#38FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
